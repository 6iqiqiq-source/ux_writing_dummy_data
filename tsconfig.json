{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "typeRoots": ["./node_modules/@types", "./node_modules/@figma"],
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["src/__tests__"]
}
